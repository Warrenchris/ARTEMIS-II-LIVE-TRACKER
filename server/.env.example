# Server Environment Variables
# Copy this file to .env and fill in the values

PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Live spacecraft telemetry — NASA trackartemis endpoint
NASA_API_URL=https://www.nasa.gov/specials/trackartemis/data/telemetry.json

# How often to poll the telemetry API (milliseconds, minimum 5000)
TELEMETRY_POLL_INTERVAL_MS=10000

# Live-data stale guard threshold: if Orion->Moon live vector distance exceeds
# this value, telemetry is flagged DATA_STALE and null is emitted to the client.
MOON_DISTANCE_STALE_LIMIT_KM=50000
