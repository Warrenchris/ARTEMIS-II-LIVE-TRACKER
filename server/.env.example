# Server Environment Variables
# Copy this file to .env and fill in the values

PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Live spacecraft telemetry — NASA trackartemis endpoint
NASA_API_URL=https://www.nasa.gov/specials/trackartemis/data/telemetry.json

# Optional: Bearer token for JPL Horizons or future authenticated endpoints
NASA_API_KEY=

# How often to poll the telemetry API (milliseconds, minimum 2000)
TELEMETRY_POLL_INTERVAL_MS=5000

# Artemis II reference launch datetime (ISO 8601 UTC)
# Update to actual launch date when confirmed
ARTEMIS_LAUNCH_DATE=2025-09-15T18:00:00.000Z

NASA_API_KEY=
TELEMETRY_POLL_INTERVAL_MS=5000
